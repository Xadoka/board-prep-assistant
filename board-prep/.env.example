# --- Secrets: never commit real values (§10 PRD) ---
ANTHROPIC_API_KEY=sk-ant-...

# Model for extraction + synthesis. PRD §11 specifies claude-sonnet-4-6.
# Swap to claude-opus-4-8 for higher quality, or claude-haiku-4-5 for lower cost.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Postgres with the pgvector extension (§6 PRD)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/board_prep

# File storage. "local" writes to ./storage; the interface is abstracted for S3 (§11).
STORAGE_DRIVER=local
STORAGE_DIR=./storage

# Optional embeddings provider for semantic search (Срез 4).
# Anthropic has no embeddings endpoint — plug in Voyage AI (voyage-3, 1024d) or
# OpenAI (text-embedding-3-small, 1536d). Leave unset to skip vector indexing.
EMBEDDINGS_PROVIDER=
EMBEDDINGS_API_KEY=
